VITE_SUPABASE_URL=tu_url_de_supabase_aqui
VITE_SUPABASE_ANON_KEY=tu_anon_key_de_supabase_aqui

# Opción 1: Supabase Edge Function (recomendada para producción)
VITE_SUPABASE_FUNCTIONS_URL=https://tu-proyecto.supabase.co/functions/v1

# Opción 2: Proxy de Vite (solo desarrollo, la key nunca llega al navegador)
# La key se lee del .env en vite.config.js (server-side) y se inyecta al proxy
VITE_GEMINI_API_KEY=tu_gemini_api_key_aqui
